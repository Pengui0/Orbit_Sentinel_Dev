# ─── DATABASE ────────────────────────────────────────────────────────────────
# Option A: TinyDB (RECOMMENDED for local/hackathon — zero setup, no Docker needed)
USE_TINYDB=true

# Option B: MongoDB (comment out USE_TINYDB and set URI below)
# USE_TINYDB=false
# MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=orbit_sentinel

# ─── SPACE DATA SOURCES ──────────────────────────────────────────────────────
# SpaceTrack credentials (https://www.space-track.org) — optional, CelesTrak works without
SPACETRACK_USERNAME=your_username_here
SPACETRACK_PASSWORD=your_password_here

# ─── SYSTEM SETTINGS ─────────────────────────────────────────────────────────
CONJUNCTION_THRESHOLD_KM=5.0
PROPAGATION_HOURS=72
RISK_THRESHOLD=0.0001
WEBHOOK_SECRET=changeme
FRONTEND_URL=http://localhost:5173
